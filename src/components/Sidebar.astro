---
interface Props {
  relatedTopics?: Array<{title: string, url: string}>;
  keyPoints?: string[];
}

const { relatedTopics = [], keyPoints = [] } = Astro.props;
---

<aside class="sidebar">
  {keyPoints.length > 0 && (
    <div class="sidebar-box">
      <h4>Key Points</h4>
      <ul>
        {keyPoints.map(point => (
          <li>{point}</li>
        ))}
      </ul>
    </div>
  )}
  
  {relatedTopics.length > 0 && (
    <div class="sidebar-box">
      <h4>Related Topics</h4>
      <ul>
        {relatedTopics.map(topic => (
          <li><a href={topic.url}>{topic.title}</a></li>
        ))}
      </ul>
    </div>
  )}
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 2rem;
  }

  .sidebar-box {
    background: #f8f7f5;
    padding: 1.5rem;
    border: 1px solid #e8e6e0;
    margin-bottom: 1.5rem;
  }

  .sidebar-box h4 {
    font-family: 'Lato', sans-serif;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #2b2b2b;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .sidebar-box ul {
    list-style: none;
    padding: 0;
  }

  .sidebar-box li {
    padding: 0.5rem 0;
    color: #5a5a5a;
    font-size: 0.95rem;
    border-bottom: 1px solid #e8e6e0;
  }

  .sidebar-box li:last-child {
    border-bottom: none;
  }

  .sidebar-box a {
    color: #2b5a8c;
    text-decoration: none;
  }

  .sidebar-box a:hover {
    text-decoration: underline;
  }

  @media (max-width: 968px) {
    .sidebar {
      position: relative;
      top: 0;
    }
  }
</style>
