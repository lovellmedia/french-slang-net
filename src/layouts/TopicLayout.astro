---
import BaseLayout from './BaseLayout.astro';
import ContentSection from '../components/ContentSection.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
  description?: string;
  topic?: string;
  pillar?: string;
  relatedTopics?: Array<{title: string, url: string}>;
  keyPoints?: string[];
}

const { title, description, topic = "Verlan", pillar, relatedTopics = [], keyPoints = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <style>
    .topic-hero {
      background: #ffffff;
      padding: 3rem 3rem 2rem;
      border-bottom: 1px solid #e8e6e0;
    }

    .topic-hero .container {
      max-width: 1000px;
      margin: 0 auto;
    }

    .breadcrumb {
      font-family: 'Lato', sans-serif;
      font-size: 0.85rem;
      color: #8a8a8a;
      margin-bottom: 1rem;
    }

    .breadcrumb a {
      color: #5a5a5a;
      text-decoration: none;
    }

    .breadcrumb a:hover {
      color: #2b2b2b;
    }

    .topic-hero h1 {
      font-size: 2.5rem;
      font-weight: 700;
      color: #1a1a1a;
      margin-bottom: 1rem;
    }

    .topic-content {
      padding: 3rem;
    }

    .topic-content .container {
      max-width: 1000px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 3rem;
    }

    @media (max-width: 968px) {
      .topic-content .container {
        grid-template-columns: 1fr;
      }

      .topic-hero {
        padding: 2rem 2rem 1.5rem;
      }

      .topic-content {
        padding: 2rem;
      }

      .topic-hero h1 {
        font-size: 1.75rem;
      }
    }
  </style>

  <div class="topic-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a> &gt; <a href="/verlan/">{topic}</a>{pillar && ` > ${pillar}`}
      </div>
      <h1>{title}</h1>
    </div>
  </div>

  <div class="topic-content">
    <div class="container">
      <div class="main-content">
        <ContentSection>
          <slot />
        </ContentSection>
      </div>
      <Sidebar relatedTopics={relatedTopics} keyPoints={keyPoints} />
    </div>
  </div>
</BaseLayout>
