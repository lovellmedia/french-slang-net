---
import { SEO } from 'astro-seo';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <SEO
    title={title}
    description={description || "The complete guide to French verlan - learn the art of French back slang, its history, mechanisms, and modern usage."}
    canonical={canonicalURL.toString()}
    noindex={false}
    nofollow={false}
  />
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Text:wght@400;600;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Crimson Text', Georgia, serif;
      line-height: 1.8;
      color: #2b2b2b;
      background: #fdfcfa;
    }

    /* Navigation */
    nav {
      background: #ffffff;
      padding: 1.25rem 0;
      border-bottom: 2px solid #d4d0c8;
    }

    nav .container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    nav .logo {
      font-family: 'Lato', sans-serif;
      font-size: 0.95rem;
      font-weight: 700;
      color: #2b2b2b;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 2.5rem;
    }

    nav a {
      color: #5a5a5a;
      text-decoration: none;
      font-size: 1rem;
      transition: color 0.2s;
    }

    nav a:hover {
      color: #2b2b2b;
    }

    .mobile-menu-toggle {
      display: none;
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
    }

    /* Responsive */
    @media (max-width: 968px) {
      nav .container {
        padding: 0 2rem;
      }

      nav ul {
        display: none;
        position: absolute;
        top: 70px;
        left: 0;
        right: 0;
        background: #ffffff;
        flex-direction: column;
        padding: 1rem 2rem;
        border-bottom: 2px solid #d4d0c8;
        gap: 1rem;
      }

      nav ul.active {
        display: flex;
      }

      .mobile-menu-toggle {
        display: block;
      }

      nav ul li {
        padding: 0.5rem 0;
      }
    }

    /* Footer */
    footer {
      background: #2b2b2b;
      color: #c4c4c4;
      padding: 3.5rem 3rem 2rem;
      border-top: 4px solid #1a1a1a;
    }

    footer .container {
      max-width: 1000px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 3rem;
      margin-bottom: 2rem;
    }

    footer h4 {
      font-family: 'Lato', sans-serif;
      color: #ffffff;
      font-size: 0.85rem;
      font-weight: 700;
      margin-bottom: 1.25rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }

    footer p {
      font-size: 0.95rem;
      line-height: 1.7;
      color: #a0a0a0;
    }

    footer ul {
      list-style: none;
    }

    footer li {
      margin-bottom: 0.75rem;
    }

    footer a {
      color: #c4c4c4;
      text-decoration: none;
      transition: color 0.2s;
    }

    footer a:hover {
      color: #ffffff;
    }

    .footer-bottom {
      text-align: center;
      padding-top: 2rem;
      border-top: 1px solid #4a4a4a;
      font-family: 'Lato', sans-serif;
      font-size: 0.85rem;
      color: #8a8a8a;
    }

    @media (max-width: 968px) {
      footer .container {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <!-- Navigation -->
  <nav>
    <div class="container">
      <a href="/" class="logo">French Slang</a>
      <button class="mobile-menu-toggle" aria-label="Toggle menu">☰</button>
      <ul id="nav-menu">
        <li><a href="/">Home</a></li>
        <li><a href="/verlan/">Overview</a></li>
        <li><a href="/verlan/history/">History</a></li>
        <li><a href="/verlan/technical-deep-dive/">Technical</a></li>
        <li><a href="/verlan/ontology/">Ontology</a></li>
        <li><a href="/verlan/trends/">Trends</a></li>
        <li><a href="/verlan/tools/">Tools</a></li>
        <li><a href="/verlan/challenges/">Challenges</a></li>
      </ul>
    </div>
  </nav>

  <script is:inline>
    document.querySelector('.mobile-menu-toggle').addEventListener('click', function() {
      document.getElementById('nav-menu').classList.toggle('active');
    });
  </script>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer>
    <div class="container">
      <div>
        <h4>French Slang</h4>
        <p>The complete guide to French verlan and colloquialisms. Dedicated to advancing understanding of French linguistic innovation through rigorous research and practical application.</p>
      </div>
      <div>
        <h4>Resources</h4>
        <ul>
          <li><a href="/verlan/">Verlan Overview</a></li>
          <li><a href="/verlan/tools/">Interactive Tools</a></li>
          <li><a href="/verlan/ontology/">Glossary</a></li>
        </ul>
      </div>
      <div>
        <h4>Navigate</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/verlan/history/">History</a></li>
          <li><a href="/verlan/trends/">Current Trends</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      © {new Date().getFullYear()} French Slang (french-slang.net). All rights reserved.
    </div>
  </footer>
</body>
</html>
